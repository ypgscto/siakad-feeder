APP_NAME="Siakad-Feeder"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Subfolder production (wajib sama persis URL browser):
# APP_URL=http://98.142.245.18/siakad-feeder/public
# ASSET_URL=http://98.142.245.18/siakad-feeder/public
# APP_SUBDIRECTORY=/siakad-feeder/public

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# MySQL (sama pola simawa-gs / simutu / sitercapai)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=siakad_feeder
DB_USERNAME=root
DB_PASSWORD=

# Dev tanpa MySQL (opsional): DB_CONNECTION=sqlite + file database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
# Subfolder production: SESSION_PATH=/siakad-feeder/public
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Siakad-API ---
SIAKAD_API_BASE_URL=http://siakad-api.test
SIAKAD_API_TOKEN=
SIAKAD_API_TIMEOUT=120
SIAKAD_KODE_ID=

# --- Neo Feeder PDDIKTI ---
FEEDER_WS_URL=http://103.167.35.204:8100/ws/live2.php
FEEDER_USERNAME=
FEEDER_PASSWORD=
FEEDER_ID_PERGURUAN_TINGGI=
FEEDER_DEFAULT_ID_WILAYAH=070000
FEEDER_PREFER_JSON=true
FEEDER_WRITE_TIMEOUT=45

# --- Auth SiFeeder ---
SIFEEDER_ALLOW_LOCAL_LOGIN_FALLBACK=true
SIFEEDER_SIAKAD_EMAIL_DOMAIN=stikesgunungsari.ac.id

