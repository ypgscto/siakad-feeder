<?xml version="1.0" encoding="UTF-8"?>
<!--
    Opsional: jika URL memakai /siakad-feeder/public tanpa alias ke folder public.
    Lebih baik: arahkan virtual host langsung ke folder public.
-->
<configuration>
    <system.webServer>
        <rewrite>
            <rules>
                <rule name="Serve from public" stopProcessing="true">
                    <match url="(.*)" />
                    <conditions>
                        <add input="{REQUEST_URI}" pattern="^/public/" negate="true" />
                    </conditions>
                    <action type="Rewrite" url="public/{R:1}" />
                </rule>
            </rules>
        </rewrite>
    </system.webServer>
</configuration>
